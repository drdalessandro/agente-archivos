# ── Backend Medplum ──────────────────────────────────────────────
# URL de tu instancia self-hosted
NEXT_PUBLIC_MEDPLUM_BASE_URL=https://api.medplum.com.ar

# ── Proyecto ─────────────────────────────────────────────────────
# ID del proyecto en Medplum (se necesita NEXT_PUBLIC_ para llegar al browser)
NEXT_PUBLIC_MEDPLUM_PROJECT_ID=

# ── Client Application (para auth server-side) ───────────────────
# Solo disponibles en el servidor (sin NEXT_PUBLIC_)
MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=

# ── Google OAuth (opcional) ───────────────────────────────────────
# NEXT_PUBLIC_MEDPLUM_GOOGLE_CLIENT_ID=
